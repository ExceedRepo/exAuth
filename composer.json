{
    "name": "exceed/exauth",
    "description": "Extended Authentication for CodeIgniter 4 — Shield's multi-auth stack with Myth-Auth's database-driven groups & permissions",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "codeigniter",
        "codeigniter4",
        "authentication",
        "authorization",
        "shield",
        "myth-auth",
        "exauth"
    ],
    "authors": [
        {
            "name": "exceed",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/ExceedRepo/exAuth",
    "support": {
        "source": "https://github.com/ExceedRepo/exAuth",
        "docs": "https://github.com/ExceedRepo/exAuth"
    },
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": ">=4.3.5 <4.5.0 || ^4.5.1",
        "firebase/php-jwt": "^7.0.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.0"
    },
    "provide": {
        "codeigniter4/authentication-implementation": "1.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "exAuth\\": "src"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests",
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "cs": "php-cs-fixer fix --ansi --verbose --dry-run",
        "cs-fix": "php-cs-fixer fix --ansi --verbose --diff",
        "analyze": "phpstan analyze"
    }
}
